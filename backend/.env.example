# Port where the Express API will run.
PORT=5000

# MariaDB/MySQL connection settings.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=skillslink_db
DB_PORT=3306

# JWT_SECRET should be long and private in real projects.
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Used by CORS so the React frontend can call this API in development.
FRONTEND_URL=http://localhost:5173
